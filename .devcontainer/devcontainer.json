{
  "name": "DevSecOps Stack",
  "dockerComposeFile": "../docker/compose.local.yml",
  "service": "workspace",
  "workspaceFolder": "/workspace/devsecops_platform_stack",
  "remoteUser": "devuser",
  "shutdownAction": "stopCompose",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "esbenp.prettier-vscode",
        "redhat.ansible",
        "ms-vscode.makefile-tools",
        "hashicorp.terraform",  
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "yzhang.markdown-all-in-one",
        "timonwong.shellcheck",
        "redhat.vscode-yaml",
        "mhutchie.git-graph",
        "github.vscode-github-actions",
        "github.vscode-pull-request-github",
        "ms-ossdata.vscode-postgresql",
        "minamijoyo.hcledit",
        "openai.chatgpt"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n",
        "editor.formatOnSave": true,
        "[yaml]": {
          "editor.defaultFormatter": "redhat.vscode-yaml"
        },
        "[terraform]": {
          "editor.defaultFormatter": "hashicorp.terraform"
        },
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "python.testing.pytestEnabled": true,
        "python.analysis.typeCheckingMode": "basic"
      }
    }
  },
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent,type=bind",
    "source=${localEnv:HOME}/.gitconfig,target=/home/devuser/.gitconfig,type=bind,readonly"
  ],
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent"
  },
  "postCreateCommand": "mkdir -p /workspace/devsecops_platform_stack/artifacts/sbom && python3 --version && poetry --version && terraform version && kubectl version --client && helm version && k3d version && ansible --version && trivy --version && tflint --version && syft version && grype version && cosign version && gh --version && docker --version && (gh auth status || true)"



}
